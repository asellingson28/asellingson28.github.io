---
import BaseLayout from '../layouts/BaseLayout.astro';
import letterboxd from '../data/letterboxd.json';

// snapshot written by `npm run fetch:media`; fetchedAt only changes when the diary does.
// The RSS feed only carries the ~50 most recent diary entries.
const { films, favorites, watchlist } = letterboxd;
const profileUrl = `https://letterboxd.com/${letterboxd.username}/`;
const updated = letterboxd.fetchedAt.slice(0, 16).replace('T', ' · ') + ' utc';

const fmtDate = (iso: string | null) =>
  iso
    ? new Date(iso + 'T00:00:00Z').toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: 'UTC',
      })
    : null;

// letterboxd ratings come in half-star steps
const stars = (r: number) => '★'.repeat(Math.floor(r)) + (r % 1 ? '½' : '');
---
<BaseLayout title="Watching" description="Films I've watched recently, pulled from my Letterboxd diary.">
  <span class="mono-label">index / 05</span>
  <h1>Watching</h1>
  <p class="lede">
    Recent entries from my <a href={profileUrl} target="_blank" rel="noopener noreferrer">Letterboxd diary</a>.
  </p>
  <p class="mono-label updated-top">most recent update / {updated}</p>

  {favorites.length > 0 && (
    <section class="favorites">
      <h2 class="mono-label section-label">four favorites</h2>
      <ul class="favorites-grid">
        {favorites.map((film) => (
          <li class="favorite">
            <a href={film.link} target="_blank" rel="noopener noreferrer">
              {film.poster && <img class="favorite-poster" src={film.poster} alt={`Poster for ${film.title}`} loading="lazy" referrerpolicy="no-referrer" />}
              <span class="favorite-title">{film.title}{film.year && <span class="film-year"> ({film.year})</span>}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {watchlist.length > 0 && (
    <section>
      <h2 class="mono-label section-label">watchlist / top {String(watchlist.length).padStart(2, '0')} most popular</h2>
      <ul class="film-grid">
        {watchlist.map((film) => (
          <li class="film">
            <a href={film.link} target="_blank" rel="noopener noreferrer">
              {film.poster && <img class="film-poster" src={film.poster} alt={`Poster for ${film.title}`} loading="lazy" referrerpolicy="no-referrer" />}
            </a>
            <a class="film-title" href={film.link} target="_blank" rel="noopener noreferrer">
              {film.title}{film.year && <span class="film-year"> ({film.year})</span>}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <h2 class="mono-label section-label">diary / last {String(films.length).padStart(2, '0')}</h2>
    <ul class="film-grid">
      {films.map((film) => (
        <li class="film">
          <a href={film.link} target="_blank" rel="noopener noreferrer">
            {film.poster && <img class="film-poster" src={film.poster} alt={`Poster for ${film.title}`} loading="lazy" referrerpolicy="no-referrer" />}
          </a>
          <a class="film-title" href={film.link} target="_blank" rel="noopener noreferrer">
            {film.title}{film.year && <span class="film-year"> ({film.year})</span>}
          </a>
          <span class="mono-label film-row">
            {film.watchedDate && <span>{fmtDate(film.watchedDate)}</span>}
            {film.rating && <span class="stars" aria-label={`Rated ${film.rating} of 5`}>{stars(film.rating)}</span>}
            {film.liked && <span class="liked" aria-label="Liked">♥</span>}
            {film.rewatch && <span class="rewatch">rewatch</span>}
          </span>
          {film.review && <p class="film-review">{film.review}</p>}
        </li>
      ))}
    </ul>
  </section>

  <footer class="data-footer">
    <span class="mono-label">source / letterboxd rss</span>
    <span class="mono-label">most recent update / {updated}</span>
  </footer>
</BaseLayout>

<style>
  .lede { color: var(--color-text-dim); }
  .lede a { color: var(--color-blue-bright); }
  .lede a:hover { color: var(--color-gold-bright); }

  .updated-top { margin: var(--space-1) 0 0; color: var(--color-text-faint); }

  section { margin-top: var(--space-4); }

  .section-label {
    color: var(--color-gold);
    border-bottom: 1px solid var(--color-line);
    padding-bottom: var(--space-1);
    margin: 0 0 var(--space-3);
    font-size: 0.7rem;
    font-weight: 400;
  }

  .favorites-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(160px, 260px));
    gap: var(--space-3);
  }
  .favorite a {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .favorite-poster {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-line);
  }
  .favorite a:hover .favorite-poster { border-color: var(--color-gold); }
  .favorite-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.3;
    color: var(--color-text);
  }
  .favorite a:hover .favorite-title { color: var(--color-gold-bright); }

  .film-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-3) var(--space-2);
  }
  .film {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }
  .film-poster {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-line);
  }
  .film a:hover .film-poster { border-color: var(--color-gold); }

  .film-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-text);
    margin-top: 0.2rem;
  }
  .film-title:hover { color: var(--color-gold-bright); }
  .film-year { color: var(--color-text-dim); font-size: 0.85em; }

  .film-row {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .stars { color: var(--color-gold); letter-spacing: 0.1em; }
  .liked { color: var(--color-gold-bright); }
  .rewatch {
    color: var(--color-gold);
    border: 1px solid var(--color-gold);
    padding: 0.05rem 0.35rem;
  }

  .film-review {
    margin: 0.15rem 0 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-text-dim);
    white-space: pre-line;
    display: -webkit-box;
    -webkit-line-clamp: 6;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .data-footer {
    margin-top: var(--space-5);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-line);
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
</style>
