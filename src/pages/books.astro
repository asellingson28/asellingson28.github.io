---
import BaseLayout from '../layouts/BaseLayout.astro';
import goodreads from '../data/goodreads.json';
import Quote from '../components/Quote.astro';
import BookGrid from '../components/BookGrid.astro';

// snapshot written by `npm run fetch:media`; fetchedAt only changes when the shelf does
const { currentlyReading, toRead, read } = goodreads;
const profileUrl = `https://www.goodreads.com/user/show/${goodreads.userId}`;
const readShelfUrl = `https://www.goodreads.com/review/list/${goodreads.userId}?shelf=read`;
const toReadShelfUrl = `https://www.goodreads.com/review/list/${goodreads.userId}?shelf=to-read`;
const updated = goodreads.fetchedAt.slice(0, 16).replace('T', ' · ') + ' utc';

const fmtDate = (iso: string | null) =>
  iso
    ? new Date(iso + 'T00:00:00Z').toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: 'UTC',
      })
    : null;

// 7 columns × 2 rows per page — matches the fixed 7-column grid in BookGrid
const PAGE_SIZE = 14;
---
<BaseLayout title="Reading" description="Books I've read, pulled from my Goodreads shelves.">
  <span class="mono-label">index / 04</span>
  <h1>Reading</h1>
  <p class="lede">
    Pulled from my <a href={profileUrl} target="_blank" rel="noopener noreferrer">Goodreads shelves</a>.
  </p>
  <Quote cite="— Albert Camus">
    You will never be able to experience everything. So, please, do poetical justice to your soul and simply experience yourself.
  </Quote>

  {currentlyReading.length > 0 && (
    <section>
      <h2 class="mono-label section-label">currently reading / {String(currentlyReading.length).padStart(2, '0')}</h2>
      <ul class="current-list">
        {currentlyReading.map((book) => (
          <li class="current-item">
            {book.cover && (
              <a href={book.link} target="_blank" rel="noopener noreferrer">
                <img class="current-cover" src={book.cover} alt={`Cover of ${book.title}`} loading="lazy" referrerpolicy="no-referrer" />
              </a>
            )}
            <div>
              <a class="book-title" href={book.link} target="_blank" rel="noopener noreferrer">{book.title}</a>
              <span class="book-author">{book.author}</span>
              {book.addedAt && <span class="mono-label">started / {fmtDate(book.addedAt)}</span>}
              {book.currentPage && book.totalPages && (
                <div class="progress">
                  <div class="progress-track">
                    <div class="progress-fill" style={`width: ${Math.round((book.currentPage / book.totalPages) * 100)}%`} />
                  </div>
                  <span class="mono-label progress-label">page {book.currentPage} / {book.totalPages}</span>
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <h2 class="mono-label section-label">
      read / {String(read.length).padStart(2, '0')}
      <a class="shelf-link" href={readShelfUrl} target="_blank" rel="noopener noreferrer">view on Goodreads →</a>
    </h2>
    <BookGrid books={read} gridId="read-grid" paginationLabel="Read shelf pages" pageSize={PAGE_SIZE} showMeta fmtDate={fmtDate} />
  </section>

  {toRead.length > 0 && (
    <section>
      <h2 class="mono-label section-label">
        want to read / {String(toRead.length).padStart(2, '0')}
        <a class="shelf-link" href={toReadShelfUrl} target="_blank" rel="noopener noreferrer">view on Goodreads →</a>
      </h2>
      <BookGrid books={toRead} gridId="toread-grid" paginationLabel="Want to read shelf pages" pageSize={PAGE_SIZE} />
    </section>
  )}

  <footer class="data-footer">
    <span class="mono-label">source / goodreads shelf rss</span>
    <span class="mono-label">most recent update / {updated}</span>
  </footer>
</BaseLayout>

<style>
  .lede { color: var(--color-text-dim); }
  .lede a { color: var(--color-blue-bright); }
  .lede a:hover { color: var(--color-gold-bright); }

  section { margin-top: var(--space-4); }

  .section-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
    color: var(--color-gold);
    border-bottom: 1px solid var(--color-line);
    padding-bottom: var(--space-1);
    margin: 0 0 var(--space-3);
    font-size: 0.7rem;
    font-weight: 400;
  }

  .shelf-link {
    color: var(--color-text-faint);
    font-weight: 400;
  }
  .shelf-link:hover { color: var(--color-blue-bright); }

  .current-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-3);
  }
  .current-item {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
    border: 1px solid var(--color-line);
    background: var(--color-bg-elevated);
    padding: var(--space-2);
  }
  .current-cover {
    width: 72px;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-line-bright);
    flex-shrink: 0;
  }
  .current-item > div {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .current-item a:hover .current-cover { border-color: var(--color-gold); }

  .book-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-text);
  }
  .book-title:hover { color: var(--color-gold-bright); }

  .book-author {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }

  .progress { margin-top: 0.15rem; }
  .progress-track {
    height: 3px;
    background: var(--color-line);
  }
  .progress-fill {
    height: 100%;
    background: var(--color-gold);
  }
  .progress-label {
    display: block;
    margin-top: 0.3rem;
    color: var(--color-text-faint);
  }

  .data-footer {
    margin-top: var(--space-5);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-line);
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
</style>
