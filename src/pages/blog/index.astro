---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import { renderInlineMarkdown, stripMarkdown } from '../../lib/inline-markdown.mjs';
import { readingTimeLabel } from '../../lib/reading-time.mjs';

// getCollection reads every .md file matched by the loader in content.config.ts
// (in dev, drafts are included so they can be edited; builds still skip them)
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.DEV || data.draft !== true;
});

const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// unique tags, ordered by first appearance across the (already date-sorted)
// posts; deduped case-insensitively so "Tech" and "tech" don't render as two
// separate filter pills, but the first-seen casing is kept for display
const tagOrder: string[] = [];
const seenTagKeys = new Set<string>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const key = tag.toLowerCase();
    if (!seenTagKeys.has(key)) {
      seenTagKeys.add(key);
      tagOrder.push(tag);
    }
  }
}

// raw post data for the dev editor's pre-filled form; never built
const devJson = import.meta.env.DEV
  ? JSON.stringify(
      posts.map((p) => ({
        id: p.id,
        title: p.data.title,
        date: p.data.date.toISOString().slice(0, 10),
        description: p.data.description ?? '',
        tags: (p.data.tags ?? []).join(', '),
        draft: p.data.draft ?? false,
        coverCaption: p.data.coverCaption ?? '',
        hasCover: Boolean(p.data.cover),
        body: p.body ?? '',
      }))
    ).replace(/</g, '\\u003c')
  : '';
---
<BaseLayout title="Writing">
  <span class="mono-label">index / 03</span>
  <div class="title-row">
    <h1>Writing</h1>
    <p class="lede">A collection of critiques, thoughts, and journaling. Often pulled straight from my obsidian vault.</p>
    {import.meta.env.DEV && (
      <button id="new-post" class="dev-btn mono-label" type="button" title="Dev only: writes src/content/blog/<slug>.md">+ new post</button>
    )}
  </div>

  <SubscribeForm />

  {tagOrder.length > 0 && (
    <ul class="tag-filter" role="list">
      <li><button type="button" class="tag-filter-btn is-active" data-tag="" aria-pressed="true">all</button></li>
      {tagOrder.map((tag) => (
        <li><button type="button" class="tag-filter-btn" data-tag={tag.toLowerCase()} aria-pressed="false" set:html={renderInlineMarkdown(tag)} /></li>
      ))}
    </ul>
  )}

  <ul class="post-list">
    {posts.map((post) => (
      <li data-tags={JSON.stringify((post.data.tags ?? []).map((t) => t.toLowerCase()))}>
        <div class="post-main">
          <a href={`/blog/${post.id}`} set:html={renderInlineMarkdown(post.data.title)} />
          {import.meta.env.DEV && post.data.draft && <span class="draft-badge mono-label">draft</span>}
          {import.meta.env.DEV && (
            <button class="post-edit dev-btn mono-label" data-id={post.id} type="button">edit</button>
          )}
          <span class="mono-label post-date">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            {' · '}
            {readingTimeLabel(post.body)}
          </span>
          {post.data.description && <p class="post-desc" set:html={renderInlineMarkdown(post.data.description)} />}
          {post.data.tags && post.data.tags.length > 0 && (
            <ul class="tag-list">
              {post.data.tags.slice(0, 3).map((tag) => (
                <li class="tag" set:html={renderInlineMarkdown(tag)} />
              ))}
              {post.data.tags.length > 3 && (
                <li class="tag tag-more" title={post.data.tags.slice(3).map(stripMarkdown).join(', ')}>+{post.data.tags.length - 3}</li>
              )}
            </ul>
          )}
        </div>
        {post.data.cover && (
          <figure class="post-cover">
            <Image src={post.data.cover} alt={post.data.coverCaption ? stripMarkdown(post.data.coverCaption) : `Cover art for ${stripMarkdown(post.data.title)}`} width={560} />
            {post.data.coverCaption && <figcaption class="mono-label" set:html={renderInlineMarkdown(post.data.coverCaption)} />}
          </figure>
        )}
      </li>
    ))}
  </ul>

  {posts.length === 0 && <p style="color: var(--color-text-dim);">No posts yet.</p>}
  <p id="no-tag-matches" class="mono-label is-hidden" style="color: var(--color-text-dim);" aria-live="polite">No posts with this tag.</p>

  {import.meta.env.DEV && <script type="application/json" id="blog-dev-data" set:html={devJson} />}
</BaseLayout>

<script>
  // tag filter — always on (not gated by DEV): clicking a tag pill shows only
  // posts carrying that tag; "all" (the default) clears the filter
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
  const postItems = document.querySelectorAll<HTMLLIElement>('.post-list > li');
  const noMatches = document.getElementById('no-tag-matches');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? '';
      filterButtons.forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-pressed', String(isActive));
      });

      let visible = 0;
      postItems.forEach((li) => {
        const tags: string[] = JSON.parse(li.dataset.tags ?? '[]');
        const show = !tag || tags.includes(tag);
        li.classList.toggle('is-hidden', !show);
        if (show) visible += 1;
      });
      noMatches?.classList.toggle('is-hidden', visible > 0);
    });
  });
</script>

<script>
  // dev-only blog editor — import.meta.env.DEV is statically false in builds,
  // so none of this ships

  if (import.meta.env.DEV) {
    interface PostData {
      id: string;
      title: string;
      date: string;
      description: string;
      tags: string;
      draft: boolean;
      coverCaption: string;
      hasCover: boolean;
      body: string;
    }

    interface PreviewResponse {
      titleHtml: string;
      descriptionHtml: string;
      tagsHtml: string[];
      coverCaptionHtml: string;
      bodyHtml: string;
    }

    const posts: PostData[] = JSON.parse(
      document.getElementById('blog-dev-data')?.textContent ?? '[]'
    );
    const esc = (s: string) => s.replace(/[&<>"']/g, (c) => `&#${c.charCodeAt(0)};`);

    const dialog = document.createElement('dialog');
    dialog.className = 'post-editor';
    document.body.append(dialog);

    const open = (p?: PostData) => {
      dialog.innerHTML = `
        <div class="post-editor-layout">
          <form id="post-form">
            <span class="mono-label">${p ? `edit · src/content/blog/${esc(p.id)}.md` : 'new post'}</span>
            <input name="title" placeholder="Title (markdown ok: **bold**, *italic*, \`code\`, [text](url))" required value="${esc(p?.title ?? '')}" />
            <div class="row">
              <input name="date" type="date" required value="${esc(p?.date ?? new Date().toISOString().slice(0, 10))}" />
              <label class="mono-label draft-toggle"><input type="checkbox" name="draft" ${p?.draft ? 'checked' : ''} /> draft</label>
            </div>
            <input name="description" placeholder="Description (markdown ok)" value="${esc(p?.description ?? '')}" />
            <input name="tags" placeholder="Tags (comma-separated, markdown ok)" value="${esc(p?.tags ?? '')}" />
            <label class="mono-label cover-label">cover art ${p?.hasCover ? '(leave empty to keep current)' : ''}
              <input type="file" name="cover" accept="image/*" />
            </label>
            <input name="coverCaption" placeholder="Cover caption / credit (markdown ok)" value="${esc(p?.coverCaption ?? '')}" />
            <label class="mono-label insert-image-label" title="${p ? 'Upload an image and insert it into the body at the cursor' : 'Save the post once first to enable inserting images'}">
              + insert image
              <input type="file" id="insert-image-input" accept="image/*" ${p ? '' : 'disabled'} />
            </label>
            <div class="row">
              <button type="submit">save post</button>
              <button type="button" id="post-preview-refresh">refresh preview</button>
              <button type="button" id="post-cancel">cancel</button>
            </div>
            <div class="row test-email-row">
              <input type="email" id="test-email-address" placeholder="dummy@address.com" title="Address to send a real test copy of the notification email to" />
              <button type="button" id="post-send-test-email">send test email</button>
            </div>
            <textarea name="body" rows="16" placeholder="Body (markdown)">${esc(p?.body ?? '')}</textarea>
          </form>
          <div id="post-preview" class="post-preview">
            <span class="mono-label">preview</span>
            <div id="post-preview-body"></div>
          </div>
        </div>`;
      dialog.showModal();

      const formEl = document.getElementById('post-form') as HTMLFormElement;
      const previewBody = document.getElementById('post-preview-body') as HTMLDivElement;

      document.getElementById('post-cancel')?.addEventListener('click', () => dialog.close());

      // the /preview endpoint runs a bare markdown processor with no asset
      // pipeline, so it can't resolve the relative paths inline images are
      // saved under — swap in blob URLs (from the still-in-memory Files) for
      // whatever this editing session has uploaded, purely for live preview;
      // the real page resolves the on-disk path correctly once saved
      const insertedImages = new Map<string, string>();

      const updatePreview = async () => {
        const fd = new FormData(formEl);
        const res = await fetch('/__edit-blog/preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: fd.get('title'),
            description: fd.get('description'),
            tags: fd.get('tags'),
            coverCaption: fd.get('coverCaption'),
            body: fd.get('body'),
          }),
        });
        if (!res.ok) {
          const { error } = await res.json().catch(() => ({ error: res.statusText }));
          alert(`Could not build preview: ${error}`);
          return;
        }
        let { titleHtml, descriptionHtml, tagsHtml, coverCaptionHtml, bodyHtml }: PreviewResponse = await res.json();
        for (const [imgPath, blobUrl] of insertedImages) {
          bodyHtml = bodyHtml.split(`src="${imgPath}"`).join(`src="${blobUrl}"`);
        }
        const cover = fd.get('cover') as File | null;
        const coverSrc = cover && cover.size > 0 ? URL.createObjectURL(cover) : null;
        const dateStr = String(fd.get('date') ?? '');
        const dateLabel = dateStr
          ? new Date(`${dateStr}T00:00:00`).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
          : '';

        previewBody.innerHTML = `
          ${dateLabel ? `<span class="mono-label">${esc(dateLabel)}</span>` : ''}
          <h1>${titleHtml}</h1>
          ${tagsHtml.length ? `<ul class="tag-list">${tagsHtml.map((t) => `<li class="tag mono-label">${t}</li>`).join('')}</ul>` : ''}
          ${
            coverSrc
              ? `<figure class="post-cover"><img src="${coverSrc}" />${coverCaptionHtml ? `<figcaption class="mono-label">${coverCaptionHtml}</figcaption>` : ''}</figure>`
              : p?.hasCover
                ? '<p class="mono-label" style="opacity: 0.6;">(existing cover art not shown in preview — pick a new file to preview a cover)</p>'
                : ''
          }
          ${descriptionHtml ? `<p class="post-desc">${descriptionHtml}</p>` : ''}
          <div class="prose">${bodyHtml}</div>
        `;
      };

      document.getElementById('post-preview-refresh')?.addEventListener('click', () => updatePreview());
      updatePreview();

      document.getElementById('post-send-test-email')?.addEventListener('click', async () => {
        const emailInput = document.getElementById('test-email-address') as HTMLInputElement;
        const to = emailInput.value.trim();
        if (!to) {
          alert('Enter an email address to send the test to.');
          emailInput.focus();
          return;
        }

        const fd = new FormData(formEl);
        // a cover just picked in the form hasn't been uploaded yet, so a sent
        // email (unlike the live on-page preview) has no blob: URL trick
        // available to show it — only a cover already saved to disk renders
        const cover = fd.get('cover') as File | null;
        if (cover && cover.size > 0) {
          const proceed = confirm(
            'The cover you just picked isn’t saved yet, so the test email will use the currently saved cover (if any) instead. Save the post first to test with the new cover. Send anyway?'
          );
          if (!proceed) return;
        }

        const button = document.getElementById('post-send-test-email') as HTMLButtonElement;
        button.disabled = true;
        button.textContent = 'sending…';
        try {
          const res = await fetch('/__edit-blog/send-test-email', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              slug: p?.id,
              title: fd.get('title'),
              description: fd.get('description'),
              coverCaption: fd.get('coverCaption'),
              to,
            }),
          });
          if (!res.ok) {
            const { error } = await res.json().catch(() => ({ error: res.statusText }));
            alert(`Could not send test email: ${error}`);
            return;
          }
          if (confirm(`Test email sent to ${to}. Open Gmail to check?`)) {
            window.open('https://mail.google.com/mail/u/0/#inbox', '_blank');
          }
        } finally {
          button.disabled = false;
          button.textContent = 'send test email';
        }
      });

      document.getElementById('insert-image-input')?.addEventListener('change', async (ev) => {
        const input = ev.currentTarget as HTMLInputElement;
        const file = input.files?.[0];
        if (!file || !p) return;
        const res = await fetch(
          `/__edit-blog/content-image?slug=${encodeURIComponent(p.id)}&name=${encodeURIComponent(file.name)}`,
          { method: 'POST', body: file }
        );
        input.value = '';
        if (!res.ok) {
          const { error } = await res.json().catch(() => ({ error: res.statusText }));
          alert(`Could not upload image: ${error}`);
          return;
        }
        const { path: imgPath } = await res.json();
        insertedImages.set(imgPath, URL.createObjectURL(file));
        const body = formEl.elements.namedItem('body') as HTMLTextAreaElement;
        const start = body.selectionStart ?? body.value.length;
        const end = body.selectionEnd ?? body.value.length;
        // markdown's image "title" doubles as a caption (rendered as a
        // <figcaption> — see rehype-image-captions.mjs); plain text only, no
        // nested markdown formatting
        const caption = window.prompt('Caption (optional, shown below the image):', '')?.trim();
        const markdown = caption ? `![](${imgPath} "${caption.replace(/"/g, '\\"')}")` : `![](${imgPath})`;
        body.value = body.value.slice(0, start) + markdown + body.value.slice(end);
        const cursor = start + markdown.length;
        body.focus();
        body.setSelectionRange(cursor, cursor);
        updatePreview();
      });

      document.getElementById('post-form')?.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const fd = new FormData(ev.currentTarget as HTMLFormElement);
        const cover = fd.get('cover') as File | null;
        const res = await fetch('/__edit-blog/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            slug: p?.id,
            title: fd.get('title'),
            date: fd.get('date'),
            description: fd.get('description'),
            tags: fd.get('tags'),
            draft: fd.get('draft') === 'on',
            coverCaption: fd.get('coverCaption'),
            body: fd.get('body'),
          }),
        });
        if (!res.ok) {
          const { error } = await res.json().catch(() => ({ error: res.statusText }));
          alert(`Could not save post: ${error}`);
          return;
        }
        const { slug } = await res.json();
        if (cover && cover.size > 0) {
          const up = await fetch(
            `/__edit-blog/image?slug=${encodeURIComponent(slug)}&name=${encodeURIComponent(cover.name)}`,
            { method: 'POST', body: cover }
          );
          if (!up.ok) {
            const { error } = await up.json().catch(() => ({ error: up.statusText }));
            alert(`Post saved, but the cover failed: ${error}`);
          }
        }
        location.reload();
      });
    };

    document.getElementById('new-post')?.addEventListener('click', () => open());
    document.querySelectorAll<HTMLButtonElement>('.post-edit').forEach((btn) =>
      btn.addEventListener('click', () => open(posts.find((p) => p.id === btn.dataset.id)))
    );
  }
</script>

<style>
  .title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .tag-filter {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: var(--space-4) 0 0;
  }
  .tag-filter-btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: none;
    color: var(--color-gold);
    border: 1px solid var(--color-gold);
    border-radius: 9999px;
    padding: 0.2rem 0.75rem;
    line-height: 1.4;
    cursor: pointer;
  }
  .tag-filter-btn:hover { color: var(--color-gold-bright); border-color: var(--color-gold-bright); }
  .tag-filter-btn.is-active {
    background: var(--color-gold);
    color: var(--color-bg);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
  }
  .post-list > li {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-line);
  }
  .post-main { flex: 1; min-width: 0; }

  .post-cover {
    flex-shrink: 0;
    width: 240px;
    margin: 0;
  }
  .post-cover img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-line);
  }
  .post-cover figcaption {
    margin-top: 0.35rem;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .post-list > li { flex-direction: column; }
    .post-cover { width: 100%; }
    .post-cover img { height: 180px; }
  }
  .post-list a {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-blue-bright);
  }
  .post-list a:hover { color: var(--color-gold-bright); }
  .post-date { display: block; margin-top: 0.3rem; }
  .post-desc { color: var(--color-text-dim); margin-top: 0.4rem; }

  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid var(--color-gold);
    border-radius: 9999px;
    padding: 0.2rem 0.75rem;
    line-height: 1;
  }
  .tag-more {
    color: var(--color-gold);
    border-color: var(--color-gold);
    opacity: 0.5;
    cursor: help;
  }

  .draft-badge {
    color: var(--color-gold-bright);
    border: 1px dashed var(--color-gold);
    padding: 0.1rem 0.4rem;
    margin-left: 0.5rem;
  }
</style>

<style is:global>
  /* dev-only editor (dialog is created by script, so styles must be global) */
  .dev-btn {
    background: none;
    border: 1px dashed var(--color-line-bright);
    color: var(--color-text-dim);
    padding: 0.25rem 0.6rem;
    cursor: pointer;
  }
  .dev-btn:hover { color: var(--color-gold-bright); border-color: var(--color-gold); }
  .post-edit { margin-left: 0.6rem; padding: 0.1rem 0.45rem; }

  .post-editor {
    width: min(1160px, 95vw);
    max-height: 90vh;
    overflow-y: auto;
    background: var(--color-bg-elevated);
    color: var(--color-text);
    border: 1px solid var(--color-line-bright);
    border-radius: 4px;
    padding: var(--space-3);
  }
  .post-editor::backdrop { background: rgba(10, 13, 18, 0.75); }
  .post-editor-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-3);
    align-items: stretch;
  }
  @media (max-width: 860px) {
    .post-editor-layout { grid-template-columns: 1fr; }
  }
  .post-editor form { display: grid; gap: 0.6rem; }
  .post-editor .row { display: flex; gap: 0.6rem; align-items: center; }
  .post-editor input,
  .post-editor textarea {
    width: 100%;
    background: var(--color-bg-inset);
    border: 1px solid var(--color-line-bright);
    color: var(--color-text);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.4rem 0.55rem;
  }
  .post-editor textarea { font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.5; }
  .post-editor input[type='date'] { width: auto; }
  .post-editor input[type='checkbox'] { width: auto; accent-color: var(--color-gold); }
  .post-editor .draft-toggle { display: flex; gap: 0.4rem; align-items: center; cursor: pointer; }
  .post-editor .cover-label { display: grid; gap: 0.25rem; }
  .post-editor input[type='file'] { border-style: dashed; }
  .post-editor .insert-image-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    border: 1px dashed var(--color-line-bright);
    padding: 0.3rem 0.6rem;
    cursor: pointer;
  }
  .post-editor .insert-image-label:hover { color: var(--color-gold-bright); border-color: var(--color-gold); }
  .post-editor .insert-image-label:has(input:disabled) { opacity: 0.5; cursor: default; }
  .post-editor .insert-image-label input[type='file'] { display: none; }
  .post-editor button[type='submit'] {
    background: var(--color-gold);
    border: none;
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.45rem 0.7rem;
    cursor: pointer;
  }
  .post-editor button[type='submit']:hover { background: var(--color-gold-bright); }
  .post-editor #post-cancel,
  .post-editor #post-preview-refresh,
  .post-editor #post-send-test-email {
    background: none;
    border: 1px solid var(--color-line-bright);
    color: var(--color-text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.45rem 0.7rem;
    cursor: pointer;
  }
  .post-editor #post-cancel:hover,
  .post-editor #post-preview-refresh:hover,
  .post-editor #post-send-test-email:hover {
    color: var(--color-gold-bright);
    border-color: var(--color-gold);
  }
  .post-editor #post-send-test-email:disabled { opacity: 0.5; cursor: default; }
  .post-editor .test-email-row input[type='email'] { flex: 1; width: auto; }

  /* rendered post-editor preview — sits beside the form as its own panel,
     mirroring the real /blog/[slug] typography closely enough to catch
     formatting mistakes, without being pixel-exact */
  .post-preview {
    display: flex;
    flex-direction: column;
    max-height: calc(90vh - 2 * var(--space-3));
    border: 1px dashed var(--color-line-bright);
    border-radius: 4px;
    padding: var(--space-3);
    min-width: 0;
    overflow-wrap: break-word;
  }
  #post-preview-body {
    flex: 1;
    overflow-y: auto;
    min-height: 0;
