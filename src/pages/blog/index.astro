---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// getCollection reads every .md file matched by the loader in content.config.ts
const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true; // skip anything marked draft: true
});

const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout title="Writing">
  <span class="mono-label">index / 02</span>
  <h1>Writing</h1>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}`}>{post.data.title}</a>
        <span class="mono-label post-date">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
        </span>
        {post.data.description && <p class="post-desc">{post.data.description}</p>}
        {post.data.tags && post.data.tags.length > 0 && (
          <ul class="tag-list">
            {post.data.tags.slice(0, 3).map((tag) => (
              <li class="tag">{tag}</li>
            ))}
            {post.data.tags.length > 3 && (
              <li class="tag tag-more">+{post.data.tags.length - 3}</li>
            )}
          </ul>
        )}
      </li>
    ))}
  </ul>

  {posts.length === 0 && <p style="color: var(--color-text-dim);">No posts yet.</p>}
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
  }
  .post-list > li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-line);
  }
  .post-list a {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-blue-bright);
  }
  .post-list a:hover { color: var(--color-gold-bright); }
  .post-date { display: block; margin-top: 0.3rem; }
  .post-desc { color: var(--color-text-dim); margin-top: 0.4rem; }

  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid var(--color-gold);
    border-radius: 9999px;
    padding: 0.2rem 0.75rem;
    line-height: 1;
  }
  .tag-more {
    color: var(--color-gold);
    border-color: var(--color-gold);
    opacity: 0.5;
  }
</style>
