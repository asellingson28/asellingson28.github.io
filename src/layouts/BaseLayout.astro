---
import Nav from '../components/Nav.astro';
import Vines from '../components/Vines.astro';
import Chains from '../components/Chains.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site — work, writing, and notes.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · aselling</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      // Restore the saved theme before first paint to avoid a flash of the default.
      try {
        var theme = localStorage.getItem('theme');
        if (theme === 'sunset' || theme === 'royal' || theme === 'monet') {
          document.documentElement.dataset.theme = theme;
        }
      } catch {}
    </script>
  </head>
  <body>
    <Vines />
    <Chains />
    <Nav />
    <main class="wrap-wide" style="padding-top: var(--space-4); padding-bottom: var(--space-5); min-height: 60vh;">
      <slot />
    </main>
    <footer class="wrap-wide site-footer">
      <span class="mono-label">© {new Date().getFullYear()} — built with Astro</span>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    padding: var(--space-3) 0 var(--space-4);
    border-top: 1px solid var(--color-line);
  }
</style>
