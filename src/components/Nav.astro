---
// Signature element: header styled after a technical drawing's title block —
// an index of numbered entries with a hairline rule, rather than a generic navbar.
const navItems = [
  { n: '01', label: 'Working', href: '/working' },
  { n: '02', label: 'Doing', href: '/projects' },
  { n: '03', label: 'Writing', href: '/blog' },
  { n: '04', label: 'Reading', href: '/books' },
  { n: '05', label: 'Watching', href: '/films' },
  { n: '06', label: 'Places', href: '/travels' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="wrap-wide bar">
    <a href="/" class="mark">
      <span class="mark-text">ASELLING</span>
      <span class="mark-sub mono-label">personal archive</span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {navItems.map((item) => {
          const active = path === item.href;
          const external = /^(https?:)?\/\//.test(item.href);
          return (
            <li>
              <a href={item.href} class:list={['nav-link', { active }]} aria-current={active ? 'page' : undefined} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
                <span class="mono-label nav-n">{item.n}</span>
                <span class="nav-label">{item.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
  <div class="wrap-wide theme-row">
    <div class="theme-switch">
      <span class="mono-label switch-name" id="theme-switch-name">theme</span>
      <div class="theme-wheel" role="group" aria-labelledby="theme-switch-name">
        <span class="wheel-needle" aria-hidden="true"></span>
        <button type="button" class="wheel-point wheel-n" data-theme-index="0" aria-label="royal" title="royal"></button>
        <button type="button" class="wheel-point wheel-e" data-theme-index="1" aria-label="sunset" title="sunset"></button>
        <button type="button" class="wheel-point wheel-s" data-theme-index="2" aria-label="cherry" title="cherry"></button>
        <button type="button" class="wheel-point wheel-w" data-theme-index="3" aria-label="monet" title="monet"></button>
      </div>
      <button type="button" class="mono-label opt" data-theme-index="0">royal</button>
      <span class="mono-label sep" aria-hidden="true">/</span>
      <button type="button" class="mono-label opt" data-theme-index="1">sunset</button>
      <span class="mono-label sep" aria-hidden="true">/</span>
      <button type="button" class="mono-label opt" data-theme-index="2">cherry</button>
      <span class="mono-label sep" aria-hidden="true">/</span>
      <button type="button" class="mono-label opt" data-theme-index="3">monet</button>
    </div>
  </div>
  <div class="rule" aria-hidden="true"></div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(6px);
  }

  .bar {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-3);
    padding-bottom: var(--space-2);
    flex-wrap: wrap;
  }

  .mark {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    line-height: 1;
  }
  .mark-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    color: var(--color-text);
  }
  .mark:hover .mark-text { color: var(--color-gold-bright); }
  .mark-sub { color: var(--color-text-faint); }

  nav ul {
    list-style: none;
    display: flex;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--color-text-dim);
    padding-bottom: 0.3rem;
    border-bottom: 1px solid transparent;
  }
  .nav-n { color: var(--color-text-faint); }

  .nav-link:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-line-bright);
  }
  .nav-link:hover .nav-n { color: var(--color-blue-bright); }

  .nav-link.active {
    color: var(--color-text);
    border-bottom-color: var(--color-gold);
  }
  .nav-link.active .nav-n { color: var(--color-gold); }

  .rule {
    height: 1px;
    background: linear-gradient(90deg, var(--color-gold) 0%, var(--color-line) 50%, var(--color-blue) 100%);
    opacity: 0.6;
  }

  .theme-row {
    display: flex;
    justify-content: flex-end;
    padding-bottom: var(--space-1);
  }

  .theme-switch {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }
  .switch-name { padding-right: 0.3rem; border-right: 1px solid var(--color-line); }

  /* 4-position dial styled as a drafting compass rose: a hairline
     circle with a needle that swings to the N/E/S/W point of the
     selected theme. */
  .theme-wheel {
    position: relative;
    width: 26px;
    height: 26px;
    flex-shrink: 0;
  }
  .theme-wheel::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-line-bright);
    border-radius: 50%;
    background: var(--color-bg-inset);
  }
  .theme-wheel::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-line-bright);
    transform: translate(-50%, -50%);
  }
  .wheel-needle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1px;
    height: 10px;
    background: var(--color-gold);
    transform-origin: 50% 100%;
    transform: translate(-50%, -100%) rotate(0deg);
    transition: transform 0.25s ease;
  }
  .wheel-point {
    position: absolute;
    width: 8px;
    height: 8px;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-line-bright);
    border-radius: 50%;
    background: var(--color-bg);
    cursor: pointer;
  }
  .wheel-point:hover { border-color: var(--color-gold); }
  .wheel-point.active { background: var(--color-gold); border-color: var(--color-gold); }
  .wheel-point:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }
  .wheel-n { top: -4px; left: 50%; transform: translate(-50%, 0); }
  .wheel-e { top: 50%; right: -4px; transform: translate(0, -50%); }
  .wheel-s { bottom: -4px; left: 50%; transform: translate(-50%, 0); }
  .wheel-w { top: 50%; left: -4px; transform: translate(0, -50%); }

  .theme-switch .opt {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-text-faint);
  }
  .theme-switch .opt:hover { color: var(--color-text-dim); }
  .theme-switch .opt.active { color: var(--color-text); }
  .sep { color: var(--color-line-bright); }

  @media (max-width: 640px) {
    nav ul { gap: var(--space-2); flex-wrap: wrap; }
    .nav-label { display: none; }
    .nav-n { font-size: 0.75rem; }
  }
</style>

<script>
  const themes = ['royal', 'sunset', 'cherry', 'monet'];
  const root = document.documentElement;
  const needle = document.querySelector<HTMLElement>('.wheel-needle')!;
  const opts = [...document.querySelectorAll<HTMLButtonElement>('.theme-switch .opt')];
  const points = [...document.querySelectorAll<HTMLButtonElement>('.theme-switch .wheel-point')];

  const sync = (index: number) => {
    needle.style.transform = `translate(-50%, -100%) rotate(${index * 90}deg)`;
    opts.forEach((opt) => opt.classList.toggle('active', Number(opt.dataset.themeIndex) === index));
    points.forEach((point) => point.classList.toggle('active', Number(point.dataset.themeIndex) === index));
  };

  const apply = (index: number) => {
    if (index === 0) {
      delete root.dataset.theme;
    } else {
      root.dataset.theme = themes[index];
    }
    sync(index);
    try {
      localStorage.setItem('theme', themes[index]);
    } catch {}
  };

  sync(Math.max(0, themes.indexOf(root.dataset.theme ?? 'royal')));
  opts.forEach((opt) => opt.addEventListener('click', () => apply(Number(opt.dataset.themeIndex))));
  points.forEach((point) => point.addEventListener('click', () => apply(Number(point.dataset.themeIndex))));
</script>
