---
interface Book {
  link: string;
  cover?: string | null;
  title: string;
  author: string;
  rating?: number;
  readAt?: string | null;
}

interface Props {
  books: Book[];
  gridId: string;
  paginationLabel: string;
  pageSize?: number;
  showMeta?: boolean;
  fmtDate?: (iso: string | null) => string | null;
}

const { books, gridId, paginationLabel, pageSize = 21, showMeta = false, fmtDate } = Astro.props;
const pages = Math.ceil(books.length / pageSize);
---
<ul class="book-grid" id={gridId}>
  {books.map((book, i) => {
    const page = Math.floor(i / pageSize) + 1;
    return (
      <li class:list={['book', { 'is-hidden': page !== 1 }]} data-page={page}>
        <a href={book.link} target="_blank" rel="noopener noreferrer">
          {book.cover && <img class="book-cover" src={book.cover} alt={`Cover of ${book.title}`} loading="lazy" referrerpolicy="no-referrer" />}
        </a>
        <a class="book-title" href={book.link} target="_blank" rel="noopener noreferrer">{book.title}</a>
        <span class="book-author">{book.author}</span>
        {showMeta && (
          <span class="mono-label book-row">
            {book.rating! > 0 && (
              <span class="stars" aria-label={`Rated ${book.rating} of 5`}>
                {'★'.repeat(book.rating!)}<span class="stars-empty">{'★'.repeat(5 - book.rating!)}</span>
              </span>
            )}
            {book.readAt && fmtDate && <span>{fmtDate(book.readAt)}</span>}
          </span>
        )}
      </li>
    );
  })}
</ul>
{pages > 1 && (
  <>
    <nav class="pagination" data-target={gridId} aria-label={paginationLabel}>
      <button type="button" class="page-btn" data-page="prev" disabled>‹ prev</button>
      {Array.from({ length: pages }, (_, i) => i + 1).map((n) => (
        <button
          type="button"
          class:list={['page-btn', 'page-num', { 'is-active': n === 1 }]}
          data-page={n}
          aria-current={n === 1 ? 'page' : undefined}
        >{n}</button>
      ))}
      <button type="button" class="page-btn" data-page="next">next ›</button>
    </nav>
    {/* pages beyond the first are marked is-hidden server-side so their
        images never enter the browser's lazy-load candidate set before the
        script below runs. Without JS, nothing toggles that class back off,
        so this restores the full list rather than stranding it on page 1
        with dead pagination controls. */}
    <noscript>
      <style>.book.is-hidden { display: flex !important; }</style>
    </noscript>
  </>
)}

<script>
  document.querySelectorAll<HTMLElement>('.pagination').forEach((nav) => {
    const targetId = nav.dataset.target;
    if (!targetId) return;
    const list = document.getElementById(targetId);
    if (!list) return;

    const items = Array.from(list.querySelectorAll<HTMLLIElement>(':scope > li'));
    const pageButtons = Array.from(nav.querySelectorAll<HTMLButtonElement>('.page-num'));
    const prevBtn = nav.querySelector<HTMLButtonElement>('[data-page="prev"]');
    const nextBtn = nav.querySelector<HTMLButtonElement>('[data-page="next"]');
    const totalPages = pageButtons.length;
    let currentPage = 1;

    const showPage = (page: number) => {
      currentPage = Math.min(Math.max(page, 1), totalPages);
      items.forEach((li) => {
        li.classList.toggle('is-hidden', Number(li.dataset.page) !== currentPage);
      });
      pageButtons.forEach((btn) => {
        const isActive = Number(btn.dataset.page) === currentPage;
        btn.classList.toggle('is-active', isActive);
        if (isActive) btn.setAttribute('aria-current', 'page');
        else btn.removeAttribute('aria-current');
      });

      // a disabled button can't hold focus -- browsers blur it immediately,
      // dropping keyboard focus to <body>. Move focus to the now-active page
      // button first so Tab/Shift+Tab continues from the pagination controls.
      const activeEl = document.activeElement;
      const focusTarget = pageButtons[currentPage - 1];
      if (prevBtn) {
        if (activeEl === prevBtn && currentPage === 1) focusTarget?.focus();
        prevBtn.disabled = currentPage === 1;
      }
      if (nextBtn) {
        if (activeEl === nextBtn && currentPage === totalPages) focusTarget?.focus();
        nextBtn.disabled = currentPage === totalPages;
      }
    };

    nav.addEventListener('click', (ev) => {
      const btn = (ev.target as HTMLElement).closest<HTMLButtonElement>('button.page-btn');
      if (!btn) return;
      const val = btn.dataset.page;
      if (val === 'prev') showPage(currentPage - 1);
      else if (val === 'next') showPage(currentPage + 1);
      else if (val) showPage(Number(val));
      list.scrollIntoView({ block: 'nearest' });
    });
  });
</script>

<style>
  .book-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: var(--space-3) var(--space-2);
  }
  .book {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }
  .book-cover {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    display: block;
    border: 1px solid var(--color-line);
  }
  .book a:hover .book-cover { border-color: var(--color-gold); }

  .book-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-text);
  }
  .book-title:hover { color: var(--color-gold-bright); }
  .book .book-title { margin-top: 0.2rem; }

  .book-author {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }

  .book-row {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .stars {
    color: var(--color-gold);
    letter-spacing: 0.1em;
  }
  .stars-empty { color: var(--color-line-bright); }

  .pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: var(--space-3);
  }
  .page-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    background: none;
    color: var(--color-text-dim);
    border: 1px solid var(--color-line);
    padding: 0.25rem 0.6rem;
    cursor: pointer;
  }
  .page-btn:hover:not(:disabled) { color: var(--color-gold-bright); border-color: var(--color-gold); }
  .page-btn:disabled { opacity: 0.35; cursor: default; }
  .page-num.is-active {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: var(--color-bg);
  }
</style>
