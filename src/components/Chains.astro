---
// Experimental ornament: a rustic chain hanging down the right edge of the
// viewport — hand-forged links alternating front-on and edge-on, slightly
// askew, with specks of rust. Purely decorative — delete this file and its
// one usage in BaseLayout.astro to remove. Color comes from the per-theme
// --color-chain token.
---

<svg class="chains" aria-hidden="true">
  <defs>
    <!-- one full link (front view) and one edge-on link, both centered at 0,0 -->
    <path
      id="chain-link"
      d="M0 -10 C3.4 -9.8 5.2 -6.2 5 -0.2 C4.8 5.8 3.2 9.6 0.2 9.9 C-3.2 10.1 -5.1 6.4 -5 0.3 C-4.9 -5.9 -3.3 -9.7 0 -10 Z"
    />
    <path
      id="chain-link-edge"
      d="M0 -6.5 C1.5 -6.2 1.8 -3.2 1.8 0 C1.8 3.2 1.5 6.2 0 6.5 C-1.5 6.2 -1.8 3.2 -1.8 0 C-1.8 -3.2 -1.5 -6.2 0 -6.5 Z"
    />

    <pattern id="chain-tile" width="32" height="160" patternUnits="userSpaceOnUse">
      <use class="link" href="#chain-link" transform="translate(16 16) rotate(3)" />
      <use class="link" href="#chain-link" transform="translate(15.6 48) rotate(-4)" />
      <use class="link" href="#chain-link" transform="translate(16.4 80) rotate(2)" />
      <use class="link" href="#chain-link" transform="translate(15.5 112) rotate(-2)" />
      <use class="link" href="#chain-link" transform="translate(16.2 144) rotate(4)" />

      <use class="edge" href="#chain-link-edge" transform="translate(16.3 32) rotate(-2)" />
      <use class="edge" href="#chain-link-edge" transform="translate(15.8 64) rotate(2)" />
      <use class="edge" href="#chain-link-edge" transform="translate(16 96) rotate(-3)" />
      <use class="edge" href="#chain-link-edge" transform="translate(16.2 128) rotate(3)" />
      <!-- the edge-on link at the tile seam, drawn at both ends so it tiles cleanly -->
      <use class="edge" href="#chain-link-edge" transform="translate(16 0) rotate(-2)" />
      <use class="edge" href="#chain-link-edge" transform="translate(16 160) rotate(-2)" />

      <circle class="rust" cx="20.5" cy="12" r="0.9" />
      <circle class="rust" cx="11.5" cy="52" r="0.8" />
      <circle class="rust" cx="19" cy="86" r="1" />
      <circle class="rust" cx="12" cy="108" r="0.8" />
      <circle class="rust" cx="20" cy="148" r="0.9" />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#chain-tile)" />
</svg>

<style>
  .chains {
    position: fixed;
    top: 0;
    right: 2px;
    width: 32px;
    height: 100vh;
    z-index: 40;
    pointer-events: none;
    opacity: 0.55;
  }

  .link {
    fill: none;
    stroke: var(--color-chain);
    stroke-width: 1.6;
    stroke-linejoin: round;
  }
  .edge {
    fill: color-mix(in srgb, var(--color-chain) 55%, transparent);
    stroke: var(--color-chain);
    stroke-width: 1;
  }
  .rust {
    fill: color-mix(in srgb, var(--color-chain) 70%, transparent);
  }

  /* stay clear of content when the viewport gets close to the layout width */
  @media (max-width: 1240px) {
    .chains { display: none; }
  }
</style>
