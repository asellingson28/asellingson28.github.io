---
// Experimental ornament: a rustic vine running down the right edge of the
// viewport — wandering stem, offshoot branches, tendrils, leaves and berries.
// Purely decorative — delete this file and its one usage in BaseLayout.astro
// to remove. Color comes from the per-theme --color-vine token.
---

<svg class="vines" aria-hidden="true">
  <defs>
    <pattern id="vine-tile" width="32" height="160" patternUnits="userSpaceOnUse">
      <path class="stem" d="M16 0 C24 15 26 25 18 40 C10 55 6 60 10 78 C14 90 24 95 22 112 C20 124 8 130 8 142 C8 150 12 152 16 160" />

      <path class="stem" d="M21 30 C26 30 29 27 30 23" />
      <path class="stem" d="M20 98 C14 100 10 98 8 94" />

      <path class="stem" d="M9 66 C15 68 19 66 19 62 C19 59 15 59 16 62" />
      <path class="stem" d="M22 34 C27 36 30 34 29 30 C28 27 25 28 26 31" />

      <path class="leaf" d="M20 12 C26 10 29 5 29 1 C23 3 20 6 20 12 Z" />
      <path class="leaf" d="M22 20 C16 18 13 14 13 9 C19 11 22 14 22 20 Z" />
      <path class="leaf" d="M18 40 C25 38 29 33 29 27 C22 29 18 33 18 40 Z" />
      <path class="leaf" d="M11 56 C5 54 2 50 2 45 C8 47 11 50 11 56 Z" />
      <path class="leaf" d="M9 74 C5 74 2 71 1 67 C5 67 9 69 9 74 Z" />
      <path class="leaf" d="M18 94 C24 92 27 88 27 83 C21 85 18 88 18 94 Z" />
      <path class="leaf" d="M22 110 C29 108 32 103 32 97 C25 99 22 103 22 110 Z" />
      <path class="leaf" d="M10 130 C4 128 1 124 1 119 C7 121 10 124 10 130 Z" />
      <path class="leaf" d="M8 146 C4 145 1 142 0 138 C4 138 8 141 8 146 Z" />
      <path class="leaf" d="M13 152 C18 150 21 146 21 142 C16 143 13 146 13 152 Z" />
      <path class="leaf" d="M30 23 C31 18 29 14 26 12 C25 16 27 20 30 23 Z" />
      <path class="leaf" d="M8 94 C4 92 2 88 3 84 C7 86 9 90 8 94 Z" />

      <circle class="berry" cx="13" cy="99" r="1.4" />
      <circle class="berry" cx="16" cy="102" r="1.4" />
      <circle class="berry" cx="12.5" cy="103" r="1.2" />
      <circle class="berry" cx="20" cy="118" r="1.4" />
      <circle class="berry" cx="22.5" cy="121" r="1.4" />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#vine-tile)" />
</svg>

<style>
  .vines {
    position: fixed;
    top: 0;
    right: 2px;
    width: 32px;
    height: 100vh;
    z-index: 40;
    pointer-events: none;
    opacity: 0.55;
  }

  .stem {
    fill: none;
    stroke: var(--color-vine);
    stroke-width: 1;
    stroke-linecap: round;
  }
  .leaf {
    fill: color-mix(in srgb, var(--color-vine) 45%, transparent);
    stroke: var(--color-vine);
    stroke-width: 1;
  }
  .berry {
    fill: color-mix(in srgb, var(--color-vine) 60%, transparent);
    stroke: var(--color-vine);
    stroke-width: 0.75;
  }

  /* stay clear of content when the viewport gets close to the layout width */
  @media (max-width: 1240px) {
    .vines { display: none; }
  }
</style>
