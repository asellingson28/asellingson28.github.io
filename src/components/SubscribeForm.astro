---
// Public "get new posts by email" signup, backed by the Cloudflare Worker in
// worker/ (see worker/README.md for deploy steps). Unlike the dev-only
// content editors elsewhere in this repo, this ships to production.
// Double opt-in: submitting here only queues a confirmation email — the
// address isn't added to the send list until that link is clicked.
//
import { WORKER_URL } from '../lib/subscribe-worker.mjs';
---

<form class="subscribe-form" id="subscribe-form" novalidate>
  <span class="mono-label subscribe-label">get new posts by email</span>
  <div class="subscribe-row">
    <input
      class="subscribe-email"
      id="subscribe-email"
      name="email"
      type="email"
      placeholder="you@example.com"
      autocomplete="email"
      required
    />
    <!-- honeypot: invisible to real visitors, left empty by them; bots that
         blindly fill every field trip this and get a silent no-op.
         Deliberately NOT named "website"/"url"/"company" etc — those names
         cause password managers (1Password, LastPass, Chrome/Safari autofill)
         to auto-populate the field on real visitors, silently killing their
         signup while the form still reports success. The data-*ignore
         attributes are exclusion hints those managers respect explicitly. -->
    <input
      class="subscribe-hp"
      name="hp-note-a1"
      type="text"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      data-1p-ignore="true"
      data-lpignore="true"
      data-bwignore="true"
      data-form-type="other"
    />
    <button type="submit" id="subscribe-submit">subscribe</button>
  </div>
  <p class="subscribe-status mono-label" id="subscribe-status" role="status" aria-live="polite"></p>
</form>

{import.meta.env.DEV && (
  <div class="dev-confirm-test">
    <span class="mono-label">dev: test confirmation email</span>
    <div class="dev-confirm-test-row">
      <input type="email" id="test-confirm-email" placeholder="dummy@address.com" title="Address to send a real test copy of the confirmation email to" />
      <button type="button" id="send-confirm-test" class="dev-btn">send test</button>
    </div>
  </div>
)}

<script define:vars={{ WORKER_URL }}>
  const form = document.getElementById('subscribe-form');
  const emailInput = document.getElementById('subscribe-email');
  const submitBtn = document.getElementById('subscribe-submit');
  const status = document.getElementById('subscribe-status');

  form?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!emailInput.checkValidity()) {
      status.textContent = 'enter a valid email address';
      return;
    }

    submitBtn.disabled = true;
    status.textContent = 'sending…';

    try {
      const res = await fetch(new URL('/subscribe', WORKER_URL), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: emailInput.value.trim(),
          website: form['hp-note-a1'].value,
        }),
      });

      if (!res.ok) throw new Error(`status ${res.status}`);

      status.textContent = 'check your email to confirm';
      form.reset();
    } catch {
      status.textContent = 'something went wrong — try again in a moment';
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>

<script>
  // dev-only "test the confirmation email" trigger — import.meta.env.DEV is
  // statically false in builds, so none of this ships
  if (import.meta.env.DEV) {
    document.getElementById('send-confirm-test')?.addEventListener('click', async () => {
      const emailInput = document.getElementById('test-confirm-email') as HTMLInputElement;
      const to = emailInput.value.trim();
      if (!to) {
        alert('Enter an email address to send the test to.');
        emailInput.focus();
        return;
      }

      const button = document.getElementById('send-confirm-test') as HTMLButtonElement;
      button.disabled = true;
      button.textContent = 'sending…';
      try {
        const res = await fetch('/__test-confirmation-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ to }),
        });
        if (!res.ok) {
          const { error } = await res.json().catch(() => ({ error: res.statusText }));
          alert(`Could not send test email: ${error}`);
          return;
        }
        alert(`Test confirmation email sent to ${to}. Its "Confirm subscription" link is a placeholder and won't actually confirm anything.`);
      } finally {
        button.disabled = false;
        button.textContent = 'send test';
      }
    });
  }
</script>

<style>
  .subscribe-form {
    margin: var(--space-3) 0;
    padding: var(--space-3);
    border: 1px solid var(--color-line);
    background: var(--color-bg-elevated);
  }

  .subscribe-label {
    display: block;
    margin-bottom: 0.6rem;
  }

  .subscribe-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .subscribe-email {
    flex: 1;
    min-width: 200px;
    background: var(--color-bg-inset);
    border: 1px solid var(--color-line-bright);
    color: var(--color-text);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.5rem 0.65rem;
  }
  .subscribe-email:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 1px;
  }

  /* honeypot: off-screen rather than display:none, which unsophisticated
     bots often specifically check for and skip filling */
  .subscribe-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .subscribe-form button[type='submit'] {
    background: var(--color-gold);
    border: none;
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.5rem 0.9rem;
    cursor: pointer;
  }
  .subscribe-form button[type='submit']:hover:not(:disabled) { background: var(--color-gold-bright); }
  .subscribe-form button[type='submit']:disabled { opacity: 0.6; cursor: default; }

  .subscribe-status {
    min-height: 1.2em;
    margin: 0.6rem 0 0;
    color: var(--color-text-dim);
  }

  .dev-confirm-test {
    margin: 0.6rem 0 var(--space-3);
    padding: var(--space-2);
    border: 1px dashed var(--color-line-bright);
  }
  .dev-confirm-test-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .dev-confirm-test-row input[type='email'] {
    flex: 1;
    min-width: 200px;
    background: var(--color-bg-inset);
    border: 1px solid var(--color-line-bright);
    color: var(--color-text);
    font: inherit;
    font-size: 0.9rem;
    padding: 0.5rem 0.65rem;
  }
  .dev-btn {
    background: none;
    border: 1px dashed var(--color-line-bright);
    color: var(--color-text-dim);
    padding: 0.25rem 0.6rem;
    cursor: pointer;
  }
  .dev-btn:hover { color: var(--color-gold-bright); border-color: var(--color-gold); }
  .dev-btn:disabled { opacity: 0.5; cursor: default; }
</style>
