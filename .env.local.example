# Copy to .env.local (gitignored, never commit it) to test the dev-only
# "send test email" buttons — the post editor's send-test-email row and the
# confirmation-email test next to SubscribeForm on /blog. `npm run dev`
# loads this automatically (node --env-file-if-exists=.env.local) if the
# file exists; nothing changes if it doesn't.
#
# Use the same values as the SMTP_*/MAIL_FROM GitHub Actions secrets, or a
# separate local-only credential from the same provider (e.g. a second
# Resend API key) — either works, see CLAUDE.md's "Email subscriptions"
# section for what each var does in production.

SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
MAIL_FROM=Your Name <hello@yourdomain.com>

# Optional — sets the Reply-To header (recipients hit "reply" and it lands
# here instead of the no-reply-style MAIL_FROM address). Also a GitHub
# Actions secret of the same name, read by deploy.yml and
# send-subscription-confirmations.yml.
# MAIL_REPLY_TO=your.real.address@gmail.com

# Optional — only needed to test the real Worker-backed unsubscribe link
# and the confirmation email's real /confirm URL (see buildUnsubscribeUrl
# in scripts/lib/mail-theme.mjs). Without these, test emails still send,
# just with a mailto: fallback unsubscribe link.
# WORKER_URL=https://aselling-blog-subscribe.aselling.workers.dev
# UNSUBSCRIBE_SECRET=
